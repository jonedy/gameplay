import React, { useEffect, useRef, useState } from "react";
import * as THREE from "three";
import { motion } from "framer-motion";
import { Compass, Heart, NotebookTabs, Sparkles, KeyRound, Gem, MousePointer2, Gamepad2 } from "lucide-react";

export default function FirstPersonFantasyGameDemo() {
  const mountRef = useRef(null);
  const engineRef = useRef({});
  const [sceneIndex, setSceneIndex] = useState(0);
  const [hoverName, setHoverName] = useState("");
  const [inventory, setInventory] = useState([]);
  const [noteOpen, setNoteOpen] = useState(false);
  const [message, setMessage] = useState("你在草地上醒来。WASD 移动，移动鼠标环顾，点击发光物体互动。");
  const [puzzleStep, setPuzzleStep] = useState(0);

  const scenes = [
    { name: "清晨草地", subtitle: "找到笔记，跟随蝴蝶进入遗迹" },
    { name: "藤蔓遗迹入口", subtitle: "拨开藤蔓，进入古老石门" },
    { name: "机关石室", subtitle: "旋转机关，让符文对齐" },
    { name: "地下花园", subtitle: "跟随精灵，获得蓝色水晶" },
  ];

  const addItem = (item) => setInventory((prev) => (prev.includes(item) ? prev : [...prev, item]));

  const gotoScene = (idx) => {
    setSceneIndex(idx);
    engineRef.current.loadScene?.(idx);
  };

  const interact = (id) => {
    if (!id) return;
    if (id === "notebook") {
      addItem("笔记");
      setNoteOpen(true);
      setMessage("笔记里画着石门与三枚符文：太阳、花、星星。也许机关需要按光线顺序旋转。");
    }
    if (id === "books") setMessage("旧书散发着青草和纸张的味道，书页边缘写着：光会记得正确的方向。");
    if (id === "flowers") setMessage("花朵被风吹动，几只发光的蝴蝶从草叶间飞起。");
    if (id === "path") {
      setMessage("你跟着蝴蝶走进林间，藤蔓深处露出古老遗迹的轮廓。");
      setTimeout(() => gotoScene(1), 500);
    }
    if (id === "vine") setMessage("你拨开藤蔓，石门上的金色纹路开始微微发光。");
    if (id === "door") {
      setMessage("石门缓缓打开，潮湿的石壁里传来机关转动声。");
      setTimeout(() => gotoScene(2), 500);
    }
    if (id === "butterfly") setMessage("蝴蝶绕着你飞了一圈，然后停在石门的符文上。");
    if (id === "wall") setMessage("壁画提示：☀️ → 🌸 → ✨。三枚符文必须排成一条光路。");
    if (id === "gear") {
      const next = (puzzleStep + 1) % 3;
      setPuzzleStep(next);
      engineRef.current.rotateGear?.(next);
      if (next === 2) {
        addItem("古代钥匙");
        setMessage("咔哒。机关对齐了。你获得古代钥匙，地下花园的入口被打开。");
        setTimeout(() => gotoScene(3), 900);
      } else {
        setMessage("机关旋转了一格，符文还没有完全对齐。继续试试。");
      }
    }
    if (id === "fairy") setMessage("光之精灵靠近你的掌心，蓝白色粒子组成一条通向水晶的路径。");
    if (id === "crystal") {
      addItem("蓝色水晶");
      setMessage("你双手托起水晶。地下花园被柔光点亮，新的区域似乎正在解锁。");
      engineRef.current.setCrystalHeld?.(true);
    }
    if (id === "exit") {
      setMessage("你带着水晶回到草地，风里多了一点魔法的回响。");
      setTimeout(() => gotoScene(0), 500);
    }
  };

  useEffect(() => {
    const mount = mountRef.current;
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(mount.clientWidth, mount.clientHeight);
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.shadowMap.enabled = true;
    mount.appendChild(renderer.domElement);

    const scene = new THREE.Scene();
    scene.fog = new THREE.Fog(0xbfefff, 10, 45);

    const camera = new THREE.PerspectiveCamera(72, mount.clientWidth / mount.clientHeight, 0.1, 100);
    camera.position.set(0, 1.65, 6);

    const clock = new THREE.Clock();
    const raycaster = new THREE.Raycaster();
    const pointer = new THREE.Vector2(0, 0);
    const keys = {};
    const interactables = [];
    const mixers = [];
    const roots = new THREE.Group();
    scene.add(roots);

    const state = {
      yaw: 0,
      pitch: 0,
      hovered: null,
      crystalHeld: false,
      gear: null,
      particles: [],
      hands: null,
    };

    const mat = {
      grass: new THREE.MeshStandardMaterial({ color: 0x7fcf62, roughness: 0.85 }),
      moss: new THREE.MeshStandardMaterial({ color: 0x497c42, roughness: 0.9 }),
      stone: new THREE.MeshStandardMaterial({ color: 0x8f8d7b, roughness: 0.8 }),
      darkStone: new THREE.MeshStandardMaterial({ color: 0x4b4037, roughness: 0.9 }),
      gold: new THREE.MeshStandardMaterial({ color: 0xffd36b, roughness: 0.35, metalness: 0.15, emissive: 0x553300 }),
      blueGlow: new THREE.MeshStandardMaterial({ color: 0x7ee7ff, roughness: 0.2, emissive: 0x31d6ff, emissiveIntensity: 1.6 }),
      pink: new THREE.MeshStandardMaterial({ color: 0xff9cb6, roughness: 0.8 }),
      paper: new THREE.MeshStandardMaterial({ color: 0xf0dfbd, roughness: 0.75 }),
      skin: new THREE.MeshStandardMaterial({ color: 0xf1bd8d, roughness: 0.55 }),
    };

    function clearScene() {
      while (roots.children.length) roots.remove(roots.children[0]);
      interactables.length = 0;
      state.particles.length = 0;
      state.gear = null;
      state.crystalHeld = false;
      camera.position.set(0, 1.65, 6);
      state.yaw = 0;
      state.pitch = 0;
    }

    function makeTextLabel(text) {
      const canvas = document.createElement("canvas");
      canvas.width = 512;
      canvas.height = 128;
      const ctx = canvas.getContext("2d");
      ctx.fillStyle = "rgba(20,16,10,0.42)";
      roundRect(ctx, 16, 24, 480, 80, 28);
      ctx.fill();
      ctx.fillStyle = "#fff4c7";
      ctx.font = "bold 36px sans-serif";
      ctx.textAlign = "center";
      ctx.fillText(text, 256, 76);
      const tex = new THREE.CanvasTexture(canvas);
      const spr = new THREE.Sprite(new THREE.SpriteMaterial({ map: tex, transparent: true }));
      spr.scale.set(2.2, 0.55, 1);
      return spr;
    }

    function roundRect(ctx, x, y, w, h, r) {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + w, y, x + w, y + h, r);
      ctx.arcTo(x + w, y + h, x, y + h, r);
      ctx.arcTo(x, y + h, x, y, r);
      ctx.arcTo(x, y, x + w, y, r);
      ctx.closePath();
    }

    function addInteractable(mesh, id, name) {
      mesh.userData.id = id;
      mesh.userData.name = name;
      interactables.push(mesh);
      const label = makeTextLabel(name);
      label.position.set(0, 0.8, 0);
      label.visible = false;
      mesh.add(label);
      mesh.userData.label = label;
      return mesh;
    }

    function addGlowOrb(x, y, z, color = 0xfff2a0, size = 0.07) {
      const orb = new THREE.Mesh(new THREE.SphereGeometry(size, 16, 16), new THREE.MeshStandardMaterial({ color, emissive: color, emissiveIntensity: 1.8 }));
      orb.position.set(x, y, z);
      const light = new THREE.PointLight(color, 0.45, 4);
      orb.add(light);
      roots.add(orb);
      state.particles.push(orb);
      return orb;
    }

    function addEnvironmentBase(bg, fog, groundColor) {
      scene.background = new THREE.Color(bg);
      scene.fog.color.set(fog);
      const hemi = new THREE.HemisphereLight(0xfff2d0, 0x335533, 2.1);
      roots.add(hemi);
      const sun = new THREE.DirectionalLight(0xfff1b8, 3.4);
      sun.position.set(-5, 8, 5);
      sun.castShadow = true;
      roots.add(sun);
      const ground = new THREE.Mesh(new THREE.PlaneGeometry(80, 80, 32, 32), new THREE.MeshStandardMaterial({ color: groundColor, roughness: 0.9 }));
      ground.rotation.x = -Math.PI / 2;
      ground.receiveShadow = true;
      roots.add(ground);
      for (let i = 0; i < 42; i++) {
        const stem = new THREE.Mesh(new THREE.ConeGeometry(0.04, 0.5 + Math.random() * 0.5, 5), mat.moss);
        stem.position.set((Math.random() - 0.5) * 28, 0.25, (Math.random() - 0.5) * 28);
        stem.rotation.z = (Math.random() - 0.5) * 0.5;
        roots.add(stem);
      }
    }

    function addHands() {
      const hands = new THREE.Group();
      const left = new THREE.Mesh(new THREE.SphereGeometry(0.18, 24, 24), mat.skin);
      const right = left.clone();
      left.scale.set(1.15, 0.65, 1.9);
      right.scale.copy(left.scale);
      left.position.set(-0.38, -0.44, -0.7);
      right.position.set(0.38, -0.44, -0.7);
      hands.add(left, right);
      camera.add(hands);
      scene.add(camera);
      state.hands = hands;
    }

    function loadMeadow() {
      addEnvironmentBase(0xbde8ff, 0xc9f5d1, 0x82c85d);
      const rug = new THREE.Mesh(new THREE.BoxGeometry(4.6, 0.05, 3.1), mat.pink);
      rug.position.set(0, 0.03, 0.2);
      roots.add(rug);
      const notebook = addInteractable(new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.08, 0.55), mat.paper), "notebook", "旧笔记本");
      notebook.position.set(-0.7, 0.12, -0.2);
      roots.add(notebook);
      const books = addInteractable(new THREE.Mesh(new THREE.BoxGeometry(1.0, 0.35, 0.7), new THREE.MeshStandardMaterial({ color: 0x374a73, roughness: 0.75 })), "books", "堆叠的书");
      books.position.set(-3.0, 0.25, -1.4);
      roots.add(books);
      const flowers = addInteractable(new THREE.Mesh(new THREE.SphereGeometry(0.45, 24, 12), new THREE.MeshStandardMaterial({ color: 0xf4a0d0, emissive: 0x442244 })), "flowers", "野花篮");
      flowers.position.set(2.5, 0.45, -1.1);
      roots.add(flowers);
      const path = addInteractable(new THREE.Mesh(new THREE.SphereGeometry(0.32, 24, 24), new THREE.MeshStandardMaterial({ color: 0xfff4a0, emissive: 0xffcc44, emissiveIntensity: 1.2 })), "path", "跟随蝴蝶");
      path.position.set(0, 1.35, -4.6);
      roots.add(path);
      for (let i = 0; i < 20; i++) addGlowOrb((Math.random() - 0.5) * 8, 1 + Math.random() * 2, -2 - Math.random() * 6, 0xfff5bb, 0.035);
    }

    function loadRuins() {
      addEnvironmentBase(0xa7e4c2, 0x98dab1, 0x5f9e4e);
      const arch = new THREE.Group();
      const left = new THREE.Mesh(new THREE.BoxGeometry(0.8, 4, 1), mat.stone);
      const right = left.clone();
      const top = new THREE.Mesh(new THREE.BoxGeometry(4.1, 0.8, 1), mat.stone);
      left.position.set(-1.6, 2, -4);
      right.position.set(1.6, 2, -4);
      top.position.set(0, 4, -4);
      arch.add(left, right, top);
      roots.add(arch);
      const door = addInteractable(new THREE.Mesh(new THREE.BoxGeometry(2.2, 3.2, 0.22), mat.darkStone), "door", "石门");
      door.position.set(0, 1.6, -3.95);
      roots.add(door);
      const vine = addInteractable(new THREE.Mesh(new THREE.TorusKnotGeometry(0.55, 0.055, 80, 8), mat.moss), "vine", "藤蔓");
      vine.position.set(-1.25, 2.2, -3.35);
      roots.add(vine);
      const butterfly = addInteractable(new THREE.Mesh(new THREE.SphereGeometry(0.22, 24, 24), new THREE.MeshStandardMaterial({ color: 0xfff4a0, emissive: 0xffdd55, emissiveIntensity: 1.5 })), "butterfly", "引路蝴蝶");
      butterfly.position.set(1.7, 2.7, -2.7);
      roots.add(butterfly);
      for (let i = 0; i < 24; i++) addGlowOrb((Math.random() - 0.5) * 10, 0.7 + Math.random() * 3, -3 - Math.random() * 9, 0xd8ffb5, 0.035);
    }

    function loadPuzzleRoom() {
      addEnvironmentBase(0x4a3a32, 0x3b2a23, 0x574337);
      roots.add(new THREE.PointLight(0xffb057, 2.8, 12).position.set(0, 3, 2));
      const wall = addInteractable(new THREE.Mesh(new THREE.BoxGeometry(7, 4, 0.4), mat.darkStone), "wall", "壁画线索");
      wall.position.set(0, 2, -4.2);
      roots.add(wall);
      const gearGroup = new THREE.Group();
      const ring = new THREE.Mesh(new THREE.TorusGeometry(0.9, 0.08, 20, 80), mat.gold);
      gearGroup.add(ring);
      for (let i = 0; i < 3; i++) {
        const spoke = new THREE.Mesh(new THREE.BoxGeometry(0.16, 0.72, 0.12), mat.gold);
        spoke.position.y = 0.56;
        spoke.rotation.z = (Math.PI * 2 * i) / 3;
        gearGroup.add(spoke);
      }
      gearGroup.position.set(0, 2.05, -3.86);
      addInteractable(gearGroup, "gear", "古代机关");
      roots.add(gearGroup);
      state.gear = gearGroup;
      for (let i = 0; i < 18; i++) addGlowOrb((Math.random() - 0.5) * 6, 0.7 + Math.random() * 2.8, -2 - Math.random() * 5, 0xffc46a, 0.03);
    }

    function loadGarden() {
      addEnvironmentBase(0x193341, 0x17404a, 0x2f6a58);
      roots.add(new THREE.PointLight(0x8aefff, 3.5, 14).position.set(0, 3, -2));
      const fairy = addInteractable(new THREE.Mesh(new THREE.SphereGeometry(0.22, 32, 32), new THREE.MeshStandardMaterial({ color: 0xdfffff, emissive: 0x88ffff, emissiveIntensity: 2.4 })), "fairy", "光之精灵");
      fairy.position.set(-1.2, 2.1, -2.7);
      roots.add(fairy);
      const crystal = addInteractable(new THREE.Mesh(new THREE.OctahedronGeometry(0.48, 0), mat.blueGlow), "crystal", "蓝色水晶");
      crystal.position.set(1.2, 1.1, -3.0);
      roots.add(crystal);
      const exit = addInteractable(new THREE.Mesh(new THREE.BoxGeometry(1, 2, 0.2), mat.stone), "exit", "回到草地");
      exit.position.set(-3.2, 1, -3.5);
      roots.add(exit);
      for (let i = 0; i < 44; i++) addGlowOrb((Math.random() - 0.5) * 11, 0.5 + Math.random() * 3.3, -1 - Math.random() * 8, 0x8eefff, 0.035);
    }

    function loadScene(idx) {
      clearScene();
      if (idx === 0) loadMeadow();
      if (idx === 1) loadRuins();
      if (idx === 2) loadPuzzleRoom();
      if (idx === 3) loadGarden();
    }

    function rotateGear(step) {
      if (state.gear) state.gear.rotation.z = (step * Math.PI * 2) / 3;
    }

    function setCrystalHeld(v) {
      state.crystalHeld = v;
    }

    function onResize() {
      const w = mount.clientWidth;
      const h = mount.clientHeight;
      renderer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }

    function onKey(e, down) {
      keys[e.code] = down;
    }

    function onMouseMove(e) {
      if (noteOpen) return;
      state.yaw -= e.movementX * 0.002;
      state.pitch -= e.movementY * 0.002;
      state.pitch = Math.max(-0.85, Math.min(0.85, state.pitch));
    }

    function onClick() {
      if (state.hovered) interact(state.hovered.userData.id);
    }

    window.addEventListener("resize", onResize);
    window.addEventListener("keydown", (e) => onKey(e, true));
    window.addEventListener("keyup", (e) => onKey(e, false));
    mount.addEventListener("mousemove", onMouseMove);
    mount.addEventListener("click", onClick);

    loadScene(0);
    addHands();

    function animate() {
      const dt = Math.min(clock.getDelta(), 0.033);
      camera.rotation.order = "YXZ";
      camera.rotation.y = state.yaw;
      camera.rotation.x = state.pitch;

      const dir = new THREE.Vector3();
      camera.getWorldDirection(dir);
      dir.y = 0;
      dir.normalize();
      const right = new THREE.Vector3().crossVectors(dir, camera.up).normalize();
      const speed = 3.4 * dt;
      if (keys.KeyW) camera.position.addScaledVector(dir, speed);
      if (keys.KeyS) camera.position.addScaledVector(dir, -speed);
      if (keys.KeyA) camera.position.addScaledVector(right, -speed);
      if (keys.KeyD) camera.position.addScaledVector(right, speed);
      camera.position.y = 1.65 + Math.sin(clock.elapsedTime * 8) * (keys.KeyW || keys.KeyA || keys.KeyS || keys.KeyD ? 0.025 : 0.006);

      raycaster.setFromCamera(pointer, camera);
      const hits = raycaster.intersectObjects(interactables, true);
      const hit = hits.find((h) => h.object.userData.id || h.object.parent?.userData.id);
      const target = hit ? (hit.object.userData.id ? hit.object : hit.object.parent) : null;
      if (state.hovered !== target) {
        if (state.hovered?.userData.label) state.hovered.userData.label.visible = false;
        state.hovered = target;
        if (state.hovered?.userData.label) state.hovered.userData.label.visible = true;
        setHoverName(state.hovered?.userData.name || "");
      }

      state.particles.forEach((p, i) => {
        p.position.y += Math.sin(clock.elapsedTime * 1.8 + i) * 0.002;
        p.rotation.y += 0.01;
      });
      if (state.gear) state.gear.rotation.z += 0.003;
      if (state.hands) state.hands.position.y = Math.sin(clock.elapsedTime * 2) * 0.01;
      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    }
    animate();

    engineRef.current = { loadScene, rotateGear, setCrystalHeld };

    return () => {
      window.removeEventListener("resize", onResize);
      mount.removeEventListener("mousemove", onMouseMove);
      mount.removeEventListener("click", onClick);
      renderer.dispose();
      mount.removeChild(renderer.domElement);
    };
  }, []);

  const current = scenes[sceneIndex];

  return (
    <div className="relative h-screen w-full overflow-hidden bg-[#10160f] text-white select-none">
      <div ref={mountRef} className="absolute inset-0 cursor-crosshair" />
      <div className="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_48%,rgba(0,0,0,0.42)_100%)]" />
      <div className="pointer-events-none absolute left-1/2 top-1/2 h-4 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full border border-white/70 shadow-[0_0_18px_rgba(255,255,210,0.9)]" />

      <div className="absolute left-5 top-5 flex items-center gap-2">
        {[1, 2, 3].map((h) => (
          <Heart key={h} className="h-7 w-7 fill-red-500 text-red-200 drop-shadow" />
        ))}
      </div>

      <div className="absolute right-5 top-5 flex items-center gap-3 rounded-2xl border border-white/20 bg-black/25 px-4 py-3 shadow-2xl backdrop-blur-md">
        <Compass className="h-5 w-5 text-amber-200" />
        <div>
          <div className="text-sm text-amber-100">{current.name}</div>
          <div className="text-xs text-white/70">{current.subtitle}</div>
        </div>
      </div>

      {hoverName && (
        <motion.div initial={{ opacity: 0, y: 8 }} animate={{ opacity: 1, y: 0 }} className="absolute left-1/2 top-[55%] -translate-x-1/2 rounded-full border border-amber-100/40 bg-black/35 px-4 py-2 text-sm text-amber-100 backdrop-blur-md">
          点击互动：{hoverName}
        </motion.div>
      )}

      <div className="absolute bottom-5 left-1/2 w-[min(780px,92vw)] -translate-x-1/2 rounded-3xl border border-white/20 bg-black/35 p-4 shadow-2xl backdrop-blur-md">
        <div className="mb-3 flex items-center gap-2 text-amber-100">
          <Sparkles className="h-5 w-5" />
          <span className="text-sm tracking-wide">冒险日志</span>
        </div>
        <p className="text-base leading-relaxed text-white/95">{message}</p>
      </div>

      <div className="absolute left-5 bottom-5 rounded-2xl border border-white/15 bg-black/25 p-3 backdrop-blur-md">
        <div className="mb-2 flex items-center gap-2 text-xs text-white/70"><Gamepad2 className="h-4 w-4" />WASD移动 · 鼠标环顾 · 点击发光物</div>
        <div className="flex gap-2">
          {inventory.includes("笔记") && <Badge icon={<NotebookTabs className="h-4 w-4" />} text="笔记" onClick={() => setNoteOpen(true)} />}
          {inventory.includes("古代钥匙") && <Badge icon={<KeyRound className="h-4 w-4" />} text="钥匙" />}
          {inventory.includes("蓝色水晶") && <Badge icon={<Gem className="h-4 w-4" />} text="水晶" />}
        </div>
      </div>

      {noteOpen && (
        <motion.div initial={{ opacity: 0, scale: 0.92 }} animate={{ opacity: 1, scale: 1 }} className="absolute inset-0 z-20 grid place-items-center bg-black/45 p-6 backdrop-blur-sm">
          <div className="max-w-lg rounded-[2rem] border border-amber-900/30 bg-[#f3dfb8] p-7 text-[#3b2614] shadow-2xl">
            <div className="mb-4 flex items-center justify-between">
              <h2 className="text-2xl font-bold">旧笔记本</h2>
              <button onClick={() => setNoteOpen(false)} className="rounded-full bg-[#3b2614]/10 px-3 py-1 text-sm">关闭</button>
            </div>
            <div className="space-y-4 text-base leading-relaxed">
              <p>“林间石门之后，有一枚会转动的太阳。让太阳、花、星星连成光线，地下花园就会醒来。”</p>
              <div className="rounded-2xl border border-[#3b2614]/20 p-4 text-center text-5xl">☀️ → 🌸 → ✨</div>
              <p className="text-sm opacity-70">提示：点击机关旋转。正确时会获得古代钥匙，并进入地下花园。</p>
            </div>
          </div>
        </motion.div>
      )}
    </div>
  );
}

function Badge({ icon, text, onClick }) {
  return (
    <button onClick={onClick} className="flex items-center gap-1 rounded-full bg-amber-200/20 px-3 py-2 text-xs text-amber-50 hover:bg-amber-200/30">
      {icon}
      {text}
    </button>
  );
}
